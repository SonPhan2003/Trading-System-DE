# Database Configuration
# Copy this file to .env and fill in your actual values
# DO NOT put your real credentials here - this file is safe to commit

DB_USER=root
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_HOST=127.0.0.1
DB_NAME=Logging
DB_PORT=3306

# Alpha Vantage API Key
# Get your free API key from: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=YOUR_KEY_HERE
ALPHAVANTAGE_OUTPUT_SIZE=compact
ALPHAVANTAGE_REQUEST_DELAY_SECONDS=15

# Comma-separated symbols for the ingestion pipeline
STOCK_SYMBOLS=AMZN,AAPL,MSFT

# AWS S3 raw landing zone
# Keep real access keys only in your local .env file
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE
AWS_REGION=ap-southeast-1
S3_RAW_BUCKET=YOUR_PRIVATE_BUCKET_NAME_HERE
S3_RAW_PREFIX=alpha_vantage/daily_prices
